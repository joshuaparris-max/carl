    .hazard { color: #92d7ff; background: linear-gradient(120deg, rgba(36,132,170,.18), rgba(0,0,0,.16)); animation: waterShimmer 1.5s infinite linear; }
    .trap { color: var(--red); background: radial-gradient(circle, rgba(232,64,64,.18), #1d0c0c 70%); }
    .rough { color: #c8c6c6; background: linear-gradient(135deg, #1f1d1d, #141414); }
    .pickup { color: #dcffe9; background: radial-gradient(circle, rgba(255,255,255,.16), #121416 70%); box-shadow: 0 0 14px rgba(255,255,255,.14); }
    .potion { color: #8fffad; background: radial-gradient(circle, rgba(69,212,131,.2), #0d1c13 70%); }

    .cell-hp {
      position: absolute;
      left: 4px;
      right: 4px;
      bottom: 3px;
      height: 3px;
      border-radius: 999px;
      background: rgba(0,0,0,.48);
      overflow: hidden;
    }
    .cell-hp span { display: block; height: 100%; background: var(--red); transition: width .18s ease; }

    /* ── RIGHT PANEL ───────────────────────────────────────────── */
    .right-panel {
      display: flex;
      flex-direction: column;
      gap: 9px;
      padding: 10px;
      overflow: hidden;
    }

    .system-box {
      flex: 0 0 auto;
      display: flex;
      flex-direction: column;
      background: #090909;
      border: 1px solid rgba(232,160,48,.32);
      border-radius: 11px;
      padding: 9px;
      box-shadow: inset 0 0 18px rgba(232,160,48,.04);
      max-height: 180px;
    }
    .system-title {
      color: var(--amber);
      font-size: 10px;
      text-transform: uppercase;
      letter-spacing: .1em;
      font-weight: 800;
      margin-bottom: 7px;
    }
    .system-log {
      display: flex;
      flex-direction: column;
      justify-content: flex-end;
      gap: 6px;
      overflow: hidden;
      flex: 1;
      font-family: "JetBrains Mono", monospace;
      font-size: 10px;
      line-height: 1.35;
      color: #f2b85c;
    }
    .sys-line { opacity: .76; }
    .sys-line.new { animation: slideIn .32s ease; opacity: 1; }
    .cursor { color: var(--amber); animation: blink 1s steps(2,start) infinite; }

    .quest-box {
      flex: 1;
      min-height: 0;
      overflow: hidden;
      display: flex;
      flex-direction: column;
      border: 1px solid rgba(255,255,255,.07);
      border-radius: 11px;
      background: rgba(0,0,0,.14);
      padding: 9px;
    }
    .quest-list {
      overflow-y: auto;
      display: grid;
      gap: 6px;
      min-height: 0;
      scrollbar-width: thin;
      scrollbar-color: rgba(232,160,48,.18) transparent;
    }
    .quest-card {
      border: 1px solid rgba(255,255,255,.07);
      border-radius: 9px;
      background: rgba(0,0,0,.16);
      padding: 6px 8px;
      display: grid;
      grid-template-columns: 15px 1fr;
      gap: 6px;
      align-items: start;
      flex-shrink: 0;
    }
    .quest-check { width: 13px; height: 13px; border-radius: 4px; border: 1px solid rgba(232,160,48,.55); margin-top: 1px; }
    .quest-card.done { opacity: .42; }
    .quest-card.done .quest-check { background: var(--amber); }
    .quest-card.done .quest-name { text-decoration: line-through; }
    .quest-name { font-size: 10px; font-weight: 800; color: var(--text); }
    .quest-desc { font-size: 9px; color: var(--muted); line-height: 1.3; margin-top: 1px; }

    .viewer-box { flex: 0 0 auto; }
    .viewer-row { margin-bottom: 7px; }
    .viewer-label { display: flex; justify-content: space-between; font-size: 10px; color: var(--muted); margin-bottom: 3px; }
    .viewer-fill { height: 100%; background: linear-gradient(90deg, var(--amber), #ffdb7b); transition: width .22s ease; }
    .viewer-fill.teal { background: linear-gradient(90deg, var(--teal), #a4ffed); }

    /* ── BOTTOM BAR ────────────────────────────────────────────── */
    .bottom-bar {
      grid-column: 1 / -1;
      display: grid;
      grid-template-columns: 1fr 240px;
      gap: 10px;
      padding: 10px 12px;
    }

    .controls-line { display: flex; flex-wrap: wrap; gap: 5px; margin-bottom: 7px; }
    .control-pill {
      font-family: "JetBrains Mono", monospace;
      font-size: 9px;
      border-radius: 999px;
      padding: 3px 7px;
      border: 1px solid rgba(232,160,48,.28);
      color: #f7cf88;
      background: rgba(232,160,48,.07);
    }
    .command-row {
      display: grid;
      grid-template-columns: 20px 1fr;
      align-items: center;
      border: 1px solid rgba(232,160,48,.38);
      border-radius: 11px;
      background: rgba(0,0,0,.34);
      padding: 8px 11px;
      font-family: "JetBrains Mono", monospace;
    }
    .prompt { color: var(--amber); font-weight: 800; }
    #commandInput {
      border: 0;
      outline: 0;
      background: transparent;
      color: var(--text);
      font: inherit;
      caret-color: var(--amber);
      width: 100%;
      font-size: 13px;
    }
    .bottom-timer { display: grid; align-content: center; gap: 7px; }
    .floor-bar { height: 16px; border-radius: 999px; background: #070707; border: 1px solid rgba(255,255,255,.07); overflow: hidden; }
    .floor-fill { height: 100%; width: 100%; background: linear-gradient(90deg, var(--green), var(--yellow), var(--red)); transition: width .2s ease; }
    .floor-caption { font-size: 10px; color: var(--muted); text-transform: uppercase; letter-spacing: .08em; font-weight: 800; }

    /* ── BANNER ────────────────────────────────────────────────── */
    .banner {
      position: fixed;
      top: 16px;
      left: 50%;
      transform: translateX(-50%) translateY(-20px);
      opacity: 0;
      pointer-events: none;
      z-index: 50;
      border: 1px solid rgba(232,160,48,.58);
      border-radius: 999px;
      background: rgba(10,8,5,.94);
      color: var(--amber);
      font-weight: 900;
      font-size: 13px;
      letter-spacing: .08em;
      padding: 9px 18px;
      box-shadow: 0 16px 48px rgba(0,0,0,.4), 0 0 28px rgba(232,160,48,.14);
    }
    .banner.show { animation: questBanner 2.2s ease forwards; }

    /* ── ANIMATIONS ────────────────────────────────────────────── */
    @keyframes pulsePlayer {
      0%,100% { box-shadow: 0 0 10px rgba(207,232,255,.12); }
      50%      { box-shadow: 0 0 22px rgba(207,232,255,.34); }
    }
    @keyframes movePop { 0% { transform: scale(.8); } 100% { transform: scale(1); } }
    @keyframes redFlash { 0%,100%{filter:none} 35%{background:#ff2d2d;color:#fff} }
    @keyframes treasureGlow {
      from { box-shadow: 0 0 10px rgba(232,160,48,.16); }
      to   { box-shadow: 0 0 26px rgba(232,160,48,.42); }
    }
    @keyframes shimmer { 0%,100%{filter:brightness(1)} 50%{filter:brightness(1.32)} }
    @keyframes waterShimmer { from{background-position:0 0} to{background-position:40px 0} }
    @keyframes blink { 50%{opacity:0} }
    @keyframes slideIn { from{transform:translateX(28px);opacity:0} to{transform:translateX(0);opacity:1} }
    @keyframes questBanner {
      0%   { opacity:0; transform:translateX(-50%) translateY(-20px); }
      12%, 80% { opacity:1; transform:translateX(-50%) translateY(0); }
      100% { opacity:0; transform:translateX(-50%) translateY(-20px); }
    }
  </style>
</head>
<body>
