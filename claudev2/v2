  </main>

  <script>
    /* ─── ZOOM ──────────────────────────────────────────────────── */
    const ZOOM_STEPS = [40, 46, 54, 62, 72, 84, 96, 110];
    const ZOOM_DEFAULT_IDX = 2; // 54px = ~comfortable default
    let zoomIdx = ZOOM_DEFAULT_IDX;

    function applyZoom() {
      const sz = ZOOM_STEPS[zoomIdx];
      const pct = Math.round((sz / ZOOM_STEPS[ZOOM_DEFAULT_IDX]) * 100);
      const grid = document.getElementById("dungeonGrid");
      grid.style.gridTemplateColumns = `repeat(12, ${sz}px)`;
      grid.style.gridTemplateRows    = `repeat(12, ${sz}px)`;
      // Scale font with cell
      const fontSize = Math.max(10, Math.round(sz * 0.38));
      grid.style.fontSize = fontSize + "px";
      document.getElementById("zoomLabel").textContent = pct + "%";
    }

    document.getElementById("zoomIn").addEventListener("click", e => {
      e.stopPropagation();
      if (zoomIdx < ZOOM_STEPS.length - 1) { zoomIdx++; applyZoom(); }
    });
    document.getElementById("zoomOut").addEventListener("click", e => {
      e.stopPropagation();
      if (zoomIdx > 0) { zoomIdx--; applyZoom(); }
    });

    // Mouse-wheel zoom over the map
    document.getElementById("mapViewport").addEventListener("wheel", e => {
      e.preventDefault();
      if (e.deltaY < 0 && zoomIdx < ZOOM_STEPS.length - 1) { zoomIdx++; applyZoom(); }
      if (e.deltaY > 0 && zoomIdx > 0)                      { zoomIdx--; applyZoom(); }
    }, { passive: false });

    // Keyboard zoom — = for in, - for out
    document.addEventListener("keydown", e => {
      if (e.target.id === "commandInput") return;
      if (e.key === "=" || e.key === "+") { if (zoomIdx < ZOOM_STEPS.length - 1) { zoomIdx++; applyZoom(); } }
      if (e.key === "-" || e.key === "_") { if (zoomIdx > 0) { zoomIdx--; applyZoom(); } }
    });

    /* ─── CONSTANTS ─────────────────────────────────────────────── */
    const maxTimer = 100;

    const baseGrid = [
      "############",
      "#..........#",
      "#......?...#",
      "#..........#",
      "#.....M....#",
      "#...====...#",
      "#.........B#",
      "#.p!.......#",
      "#....~^!.g.#",
      "#DC........#",
      "#..........#",
      "############"
    ].map(r => r.split(""));

    /* ─── GAME STATE ────────────────────────────────────────────── */
    const state = {
      turn: 0, timer: 100,
      systemLog: [], lastMoved: false, lastHitEnemy: null,
      entities: {
        carl: { id:"carl", name:"Carl", symbol:"C", x:2, y:9, level:1, xp:0, hp:12, maxHp:12,
          armor:1, stats:{strength:5,dexterity:4,charisma:3},
          inventory:["leather_jacket"], equipment:{torso:"leather_jacket"},
          debuffs:["no_pants"], type:"player" },
        donut: { id:"donut", name:"Princess Donut", symbol:"D", x:1, y:9, level:0, xp:0, hp:5, maxHp:5,
          armor:0, stats:{strength:1,dexterity:7,charisma:9},
          inventory:[], equipment:{}, debuffs:["civilian"],
          mode:"follow", title:"Grand Champion", type:"companion" },
        mordecai: { id:"mordecai", name:"Mordecai", symbol:"M", x:6, y:4, hp:20, maxHp:20, armor:0, type:"npc" },
        bopca:    { id:"bopca",    name:"Bopca Clerk", symbol:"B", x:10, y:6, hp:10, maxHp:10, armor:0, type:"npc" },
        goblin:   { id:"goblin",   name:"Training Goblin", symbol:"g", x:9, y:8, hp:6, maxHp:6, armor:0, type:"monster" }
      },
      objects: [
        { id:"chest",  name:"Tutorial Chest",            symbol:"?", x:7,  y:2, type:"chest",  opened:false, contains:["unstable_powder"] },
        { id:"pants",  name:"Threadbare Pants",          symbol:"!", x:3,  y:7, type:"pickup", picked:false, item:"threadbare_pants" },
        { id:"potion", name:"Stale Healing Bar",         symbol:"p", x:2,  y:7, type:"pickup", picked:false, item:"stale_healing_bar" },
        { id:"item2",  name:"Dungeon Scrap",             symbol:"!", x:6,  y:8, type:"pickup", picked:false, item:"stale_healing_bar" },
        { id:"shop",   name:"Overpriced Tutorial Kiosk", symbol:"$", x:10, y:7, type:"shop",   stock:["stale_healing_bar"] }
      ],
      hazards: [
        { id:"grime", name:"Suspicious Grime Patch", symbol:"~", x:5, y:8, effect:"filth",  severity:0 },
        { id:"rough", name:"Rough Tile",             symbol:"^", x:6, y:8, effect:"rough",  severity:1 },
        { id:"trap",  name:"Training Trap",          symbol:"^", x:7, y:8, effect:"trap",   severity:3 }
      ],
      items: {
        leather_jacket:      { name:"Carl's Leather Jacket",      slot:"torso",       armor:1, durability:12, tags:["equipment"] },
        unstable_powder:     { name:"Unstable Dungeon Powder",    slot:"material",    craftingPower:2, tags:["material","explosive_component"] },
        crude_blast_charge:  { name:"Crude Blast Charge",         slot:"combat_item", damage:4, accuracy:90, tags:["explosive","consumable"] },
        threadbare_pants:    { name:"Threadbare Tutorial Pants",  slot:"legs",        armor:1, durability:5,  tags:["equipment"] },
        stale_healing_bar:   { name:"Stale Healing Bar",          slot:"consumable",  healing:4, tags:["healing","consumable"] }
      },
      quests: [
        q("speak",     "Listen Before Dying",   "Talk to Mordecai and learn the first survival rules.",              "spoke_to_mordecai"),
        q("inventory", "Inventory Check",       "Confirm the jacket is real gear and the lack of pants is real trouble.", "inspected_inventory"),
        q("chest",     "Questionable Gift",     "Open the tutorial chest and recover the first explosive material.", "opened_tutorial_chest"),
        q("craft",     "Carl Makes A Problem",  "Craft the first crude explosive from dungeon materials.",           "crafted_first_explosive"),
        q("blood",     "First Blood",           "Defeat the tutorial enemy without pretending this is normal.",      "defeated_enemy"),
        q("pants",     "Dress Code Violation",  "Find something, anything, that counts as pants.",                  "picked_up_item"),
        q("flooring",  "Bad Flooring",          "Learn that terrain can hate you too.",                              "triggered_hazard")
      ],
      viewer: { party:0, carl:0, donut:4 },
      dialogueIndex: { mordecai:0, bopca:0 },
      checkpoint: null
    };

    const dialogue = {
      mordecai: [
        "Mordecai: Listen carefully. You are alive, classless, underdressed, and already behind schedule. That is not a strategy.",
        "Mordecai: The cat is Level 0. Civilian. Do not let her get hit. Do not let yourself get hit either, but especially do not let the cat get hit.",
        "Mordecai: The System has rules. Bad rules. Cruel rules. But rules can be used, and that is the only reason I am still talking to you."
      ],
      bopca: [
        "Bopca Clerk: You want affordable prices? That is adorable. I sell survival, not hope.",
        "Bopca Clerk: The cat gets a discount if she stops staring at me like that."
      ]
    };

    const controls = [
      "WASD move","X attack","U use item","T talk","O open","I inventory",
      "C craft","E equip","P pickup","B buy","F follow","H hide","R retreat",
      "V save","L load","K checkpoint","= zoom in","- zoom out","Q quit"
    ];

    function q(id, name, desc, event) {
      return { id, name, desc, event, current:0, target:1, complete:false };
    }

    /* ─── SYSTEM ────────────────────────────────────────────────── */
    function system(text) {
      state.systemLog.push("SYSTEM: " + text);
      state.systemLog = state.systemLog.slice(-5);
      renderSystem();
    }

    function completeQuest(event) {
      for (const quest of state.quests) {
        if (quest.event === event && !quest.complete) {
          quest.current = Math.min(quest.target, quest.current + 1);
          if (quest.current >= quest.target) {
            quest.complete = true;
            showBanner("QUEST COMPLETE — " + quest.name);
          }
        }
      }
    }

    function changeViewer(which, amount) {
      state.viewer[which] = Math.max(0, state.viewer[which] + amount);
      state.viewer.party  = Math.max(0, state.viewer.party + Math.max(0, Math.floor(amount / 2)));
      if (state.viewer.party >= 10) {
        system("Sponsor interest detected. Somewhere, someone with too much money enjoyed that.");
        state.viewer.party = 0;
      }
    }

    /* ─── WORLD HELPERS ─────────────────────────────────────────── */
    function tileAt(x, y) {
      if (y < 0 || y >= baseGrid.length || x < 0 || x >= baseGrid[0].length) return "#";
      return baseGrid[y][x];
    }
    function entityAt(x, y) {
      return Object.values(state.entities).find(e => e.x === x && e.y === y && e.hp > 0);
    }
    function objectAt(x, y) {
      return state.objects.find(o => o.x === x && o.y === y && !o.picked && !(o.type === "chest" && o.opened));
    }
    function hazardAt(x, y) {
      return state.hazards.find(h => h.x === x && h.y === y);
    }
    function blocked(x, y, ignore = []) {
      if (["#","="].includes(tileAt(x, y))) return true;
      const obj = objectAt(x, y);
      if (obj && obj.blocks) return true;
      const ent = entityAt(x, y);
      return ent && !ignore.includes(ent.id);
    }
    function near(a, b, d = 1) {
      return Math.abs(a.x - b.x) <= d && Math.abs(a.y - b.y) <= d;
    }

    /* ─── TURN ENGINE ───────────────────────────────────────────── */
    function advanceTurn() {
      state.turn  += 1;
      state.timer  = Math.max(0, state.timer - 1);
      donutSupport();
      enemyTurn();
      if ([30,10,5].includes(state.timer))
        system(`Timer warning: ${state.timer} turns remain. Panic is a renewable resource.`);
      if (state.timer === 0)
        system("The floor timer hit zero. This run is over. The System sends thoughts and no prayers.");
    }

    /* ─── ACTIONS ───────────────────────────────────────────────── */
    function move(dx, dy) {
      const carl = state.entities.carl;
      const nx = carl.x + dx, ny = carl.y + dy;
      if (blocked(nx, ny, ["carl"])) {
        system("Crawler 4411 has located an obstacle. The obstacle remains undefeated.");
        return true;
      }
      const prev = { x: carl.x, y: carl.y };
      carl.x = nx; carl.y = ny; state.lastMoved = true;
      followDonut(prev);
      const hazard = hazardAt(nx, ny);
      if (hazard) applyHazard(hazard);
      const npc = nearestNpc();
      if (npc) system(`${npc.name} is close enough to talk. Press T.`);
      else donutBanter();
      completeQuest("player_moved");
      return true;
    }

    function followDonut(prev) {
      const donut = state.entities.donut;
      if (donut.mode !== "follow") return;
      if (!blocked(prev.x, prev.y, ["donut","carl"])) {
        donut.x = prev.x; donut.y = prev.y; return;
      }
      const carl = state.entities.carl;
      const dirs = [
        [Math.sign(carl.x - donut.x), 0],
        [0, Math.sign(carl.y - donut.y)],
        [0,-1],[1,0],[0,1],[-1,0]
      ];
      for (const [dx, dy] of dirs) {
        if ((dx || dy) && !blocked(donut.x + dx, donut.y + dy, ["donut"])) {
          donut.x += dx; donut.y += dy; return;
        }
      }
    }

    function donutBanter() {
      const lines = [
        "Donut: Carl, this floor is unspeakably filthy.",
        "Donut: I can feel the grime between my toes. This is a hate crime against grooming.",
        "Donut: My fans must never see me like this. Walk softer."
      ];
      const idx = Math.min(state.dialogueIndex.mordecai, lines.length - 1);
      system(lines[idx]);
    }

    function applyHazard(hazard) {
      if (hazard.effect === "trap") {
        const dmg = Math.max(1, hazard.severity - state.entities.carl.armor);
        state.entities.carl.hp = Math.max(0, state.entities.carl.hp - dmg);
        system(`Trap triggered: Carl takes ${dmg} damage. The floor has entered the conversation.`);
        completeQuest("triggered_hazard");
      } else if (hazard.effect === "rough") {
        system("Rough terrain. The System applauds the floor's initiative.");
        completeQuest("triggered_hazard");
      } else {
        system("Donut: Carl, this tile smells like wet garbage with ambition.");
      }
    }

    function nearestNpc() {
      return Object.values(state.entities).find(e => e.type === "npc" && near(state.entities.carl, e));
    }

    function talk() {
      const npc = nearestNpc();
      if (!npc) { system("There is nobody close enough to talk to. Somehow, this is still awkward."); return true; }
      const lines = dialogue[npc.id] || [];
      const idx = state.dialogueIndex[npc.id] || 0;
      system(lines[idx] || `${npc.name}: ...`);
      state.dialogueIndex[npc.id] = Math.min(idx + 1, Math.max(0, lines.length - 1));
      if (npc.id === "mordecai" && idx >= 1) completeQuest("spoke_to_mordecai");
      return true;
    }

    function openNearby() {
      const carl = state.entities.carl;
      const chest = state.objects.find(o =>
        o.type === "chest" && !o.opened &&
        Math.abs(o.x - carl.x) <= 1 && Math.abs(o.y - carl.y) <= 1);
      if (!chest) { system("Nothing nearby opens. The desk remains aggressively desk-shaped."); return true; }
      chest.opened = true;
      for (const item of chest.contains) state.entities.carl.inventory.push(item);
      system("Loot event registered. Try not to treat this as proof you are good at decisions.");
      completeQuest("opened_tutorial_chest");
      return true;
    }

    function inventory() {
      system("Inventory inspected. NOTICE: Pants have not been located. The System is deeply unsurprised.");
      completeQuest("inspected_inventory");
      return true;
    }

    function craft() {
      const inv = state.entities.carl.inventory;
      const idx = inv.indexOf("unstable_powder");
      if (idx < 0) { system("Carl needs something unstable before he can make something worse."); return true; }
      inv.splice(idx, 1);
      inv.push("crude_blast_charge");
      system("Crafting update: crude explosive assembled. The viewers have upgraded you from doomed to interesting.");
      completeQuest("crafted_first_explosive");
      changeViewer("carl", 4);
      return true;
    }

    function attack(useItem = false) {
      const enemy = Object.values(state.entities).find(
        e => e.type === "monster" && e.hp > 0 && near(state.entities.carl, e, useItem ? 3 : 1));
      if (!enemy) {
        system(useItem
          ? "No enemy is close enough to make this a responsible bad idea."
          : "Carl swings at the concept of danger. Nothing happens.");
        return true;
      }
      let dmg = Math.max(0, 2 + Math.floor(state.entities.carl.stats.strength / 2) - enemy.armor);
      if (useItem) {
        const inv = state.entities.carl.inventory;
        const iIdx = inv.findIndex(id => (state.items[id].tags || []).includes("explosive"));
        if (iIdx < 0) { system("Carl has nothing explosively useful ready."); return true; }
        const item = inv.splice(iIdx, 1)[0];
        dmg = Math.max(0, state.items[item].damage - enemy.armor);
        changeViewer("carl", 6);
      } else {
        changeViewer("carl", 1);
      }
      enemy.hp = Math.max(0, enemy.hp - dmg);
      state.lastHitEnemy = enemy.id;
      system(`Carl hits ${enemy.name} for ${dmg} damage.`);
      if (enemy.hp <= 0) {
        system(`${enemy.name} is defeated. Achievement unlocked: Applied Learning.`);
        completeQuest("defeated_enemy");
      }
      return true;
    }

    function donutSupport() {
      const donut  = state.entities.donut;
      const enemy  = Object.values(state.entities).find(
        e => e.type === "monster" && e.hp > 0 && near(donut, e, 2));
      if (!enemy || donut.mode === "hide") return;
      enemy.hp = Math.max(0, enemy.hp - 1);
      state.lastHitEnemy = enemy.id;
      system(`Donut swipes at ${enemy.name} for 1 damage. The audience makes an undignified noise.`);
      if (enemy.hp <= 0) {
        completeQuest("defeated_enemy");
        changeViewer("donut", 8);
      }
    }

    function enemyTurn() {
      const enemy = state.entities.goblin;
      if (!enemy || enemy.hp <= 0) return;
      const targets = [state.entities.carl, state.entities.donut]
        .filter(t => t.hp > 0 && near(enemy, t, 1));
      if (!targets.length) return;
      const target = targets.sort((a,b) => a.hp - b.hp)[0];
      const dmg = Math.max(0, 2 - target.armor);
      target.hp = Math.max(0, target.hp - dmg);
      system(`${enemy.name} claws ${target.name} for ${dmg} damage.`);
    }

    function pickup() {
      const carl = state.entities.carl;
      const obj = state.objects.find(
        o => o.type === "pickup" && !o.picked && o.x === carl.x && o.y === carl.y);
      if (!obj) { system("There is nothing here to pick up. Carl briefly considers picking up his dignity."); return true; }
      obj.picked = true;
      carl.inventory.push(obj.item);
      system(`Picked up ${state.items[obj.item].name}. The System refuses to call this fashion.`);
      completeQuest("picked_up_item");
      return true;
    }

    function equip() {
      const carl = state.entities.carl;
      const equipped = new Set(Object.values(carl.equipment));
      const itemId = carl.inventory.find(
        id => !equipped.has(id) && ["torso","legs","weapon"].includes(state.items[id].slot));
      if (!itemId) { system("No unequipped gear available. This remains a wardrobe emergency."); return true; }
      const item = state.items[itemId];
      carl.equipment[item.slot] = itemId;
      recalcArmor();
      if (item.slot === "legs") carl.debuffs = carl.debuffs.filter(d => d !== "no_pants");
      system(`Equipped ${item.name}. The System grudgingly acknowledges progress.`);
      return true;
    }

    function recalcArmor() {
      const carl = state.entities.carl;
      carl.armor = Object.values(carl.equipment)
        .reduce((sum, id) => sum + (state.items[id].armor || 0), 0);
    }

    function buy() {
      const carl = state.entities.carl;
      const shop = state.objects.find(o =>
        o.type === "shop" && Math.abs(o.x - carl.x) <= 1 && Math.abs(o.y - carl.y) <= 1);
      if (!shop) { system("No shop is close enough to overcharge you."); return true; }
      carl.inventory.push(shop.stock[0]);
      system(`Bought ${state.items[shop.stock[0]].name}. Capitalism has survived the apocalypse.`);
      return true;
    }

    function companionMode(mode) {
      state.entities.donut.mode = mode;
      system(`Donut mode set to ${mode}. Donut has filed a verbal objection.`);
      return true;
    }

    function saveGame() {
      state.checkpoint = JSON.parse(JSON.stringify({
        entities: state.entities, objects: state.objects,
        quests: state.quests, viewer: state.viewer,
        timer: state.timer, turn: state.turn
      }));
      try {
        localStorage.setItem("dcc-browser-save", JSON.stringify(state.checkpoint));
      } catch(e) {}
      system("Game saved. The System promises nothing about emotional safety.");
      return true;
    }

    function loadGame() {
      let raw = null;
      try { raw = localStorage.getItem("dcc-browser-save"); } catch(e) {}
      if (!raw) { system("No save file exists yet. Bold strategy."); return true; }
      restore(JSON.parse(raw));
      system("Game loaded. Previous mistakes are now current mistakes.");
      return true;
    }

    function restoreCheckpoint() {
      if (!state.checkpoint) { system("No checkpoint exists yet. The System enjoys your optimism."); return true; }
      restore(state.checkpoint);
      system("Checkpoint restored. Reality has been politely rewound.");
      return true;
    }

    function restore(data) {
      state.entities = JSON.parse(JSON.stringify(data.entities));
      state.objects  = JSON.parse(JSON.stringify(data.objects));
      state.quests   = JSON.parse(JSON.stringify(data.quests));
      state.viewer   = JSON.parse(JSON.stringify(data.viewer));
      state.timer    = data.timer;
      state.turn     = data.turn;
    }

    /* ─── INPUT ROUTING ─────────────────────────────────────────── */
    function runAction(action) {
      state.lastMoved = false;
      state.lastHitEnemy = null;
      action = action.trim().toLowerCase();
      let acted = false;
      const dirs = { w:[0,-1], a:[-1,0], s:[0,1], d:[1,0] };
      if (dirs[action])          acted = move(...dirs[action]);
      else if (action === "t")   acted = talk();
      else if (action === "o")   acted = openNearby();
      else if (action === "i")   acted = inventory();
      else if (action === "c")   acted = craft();
      else if (action === "x")   acted = attack(false);
      else if (action === "u")   acted = attack(true);
      else if (action === "p")   acted = pickup();
      else if (action === "e")   acted = equip();
      else if (action === "b")   acted = buy();
      else if (action === "f")   acted = companionMode("follow");
      else if (action === "h")   acted = companionMode("hide");
      else if (action === "r")   acted = companionMode("retreat");
      else if (action === "v")   acted = saveGame();
      else if (action === "l")   acted = loadGame();
      else if (action === "k")   acted = restoreCheckpoint();
      else if (action === "q")   { system("Run ended. The viewers have filed a complaint about the lack of screaming."); acted = false; }
      else                       system("Invalid command. The System has added this to your permanent record.");

      if (acted && action !== "q") advanceTurn();
      render();
    }

    /* ─── CLICK HANDLERS ────────────────────────────────────────── */
    function clickCell(x, y) {
      const e = entityAt(x, y);
      const o = objectAt(x, y);
      if (e && e.type === "monster")
        return runAction(near(state.entities.carl, e, 1) ? "x" : "u");
      if (e && e.type === "npc")  return runAction("t");
      if (o && o.type === "chest") return runAction("o");
      if (o && o.type === "pickup") {
        if (state.entities.carl.x === x && state.entities.carl.y === y)
          return runAction("p");
        return stepToward(x, y);
      }
      if (o && o.type === "shop") return runAction("b");
      return stepToward(x, y);
    }

    function stepToward(x, y) {
      const carl = state.entities.carl;
      const dx = Math.sign(x - carl.x);
      const dy = Math.sign(y - carl.y);
      if (Math.abs(x - carl.x) >= Math.abs(y - carl.y) && dx)
        runAction(dx > 0 ? "d" : "a");
      else if (dy)
        runAction(dy > 0 ? "s" : "w");
      else if (dx)
        runAction(dx > 0 ? "d" : "a");
    }

    /* ─── RENDER ────────────────────────────────────────────────── */
    function hpColor(pct) {
      if (pct > .55) return "linear-gradient(90deg,#45d483,#9ee85c)";
      if (pct > .25) return "linear-gradient(90deg,#e5c94b,#e8a030)";
      return "linear-gradient(90deg,#e84040,#ff7a62)";
    }

    function render() {
      renderGrid();
      renderCharacters();
      renderInventory();
      renderQuests();
      renderViewers();
      renderTimers();
    }

    function renderGrid() {
      const grid = document.getElementById("dungeonGrid");
      grid.innerHTML = "";
      for (let y = 0; y < 12; y++) {
        for (let x = 0; x < 12; x++) {
          const cell = document.createElement("div");
          let symbol = tileAt(x, y);
          let cls = "";
          if (symbol === "#") cls = "wall";
          if (symbol === "=") cls = "desk";

          const hz = hazardAt(x, y);
          if (hz) {
            symbol = hz.symbol;
            cls = hz.effect === "trap" ? "trap" : hz.effect === "rough" ? "rough" : "hazard";
          }
          const obj = objectAt(x, y);
          if (obj) {
            symbol = obj.symbol;
            cls = obj.type === "chest" ? "chest"
                : obj.type === "shop"  ? "shop"
                : obj.item === "stale_healing_bar" ? "potion"
                : "pickup";
          }
          const ent = entityAt(x, y);
          if (ent) {
            symbol = ent.id === "donut" ? "🐱" : ent.symbol;
            cls = ent.type === "player"    ? "player"
                : ent.type === "companion" ? "donut-cell"
                : ent.type === "monster"   ? "enemy"
                : ent.id === "bopca"       ? "merchant"
                : "npc";
            if (ent.type === "player" && state.lastMoved) cls += " moved";
            if (ent.id === state.lastHitEnemy)            cls += " hit";
          }

          cell.className = "cell " + cls;
          cell.textContent = symbol === "." ? "" : symbol;

          if (ent && ent.type === "monster") {
            const hp = document.createElement("div");
            hp.className = "cell-hp";
            hp.innerHTML = `<span style="width:${(ent.hp/ent.maxHp)*100}%"></span>`;
            cell.appendChild(hp);
          }
          cell.addEventListener("click", () => clickCell(x, y));
          grid.appendChild(cell);
        }
      }
    }

    function renderCharacters() {
      const carl = state.entities.carl, donut = state.entities.donut;
      document.getElementById("carlLevel").textContent    = "LVL " + carl.level;
      document.getElementById("carlHpText").textContent   = carl.hp + "/" + carl.maxHp;
      const cp = carl.hp / carl.maxHp;
      document.getElementById("carlHp").style.width      = (cp * 100) + "%";
      document.getElementById("carlHp").style.background = hpColor(cp);
      document.getElementById("carlArmor").textContent   = carl.armor;
      document.getElementById("carlGear").textContent    =
        Object.values(carl.equipment).map(id => state.items[id].name.replace("Carl's ","")).join(", ") || "None";
      document.getElementById("carlBadges").innerHTML    =
        carl.debuffs.map(d => `<span class="badge danger">${d.replace("_"," ")}</span>`).join("") +
        `<span class="badge amber">XP ${carl.xp}</span>`;

      document.getElementById("donutLevel").textContent   = "LVL " + donut.level;
      document.getElementById("donutHpText").textContent  = donut.hp + "/" + donut.maxHp;
      const dp = donut.hp / donut.maxHp;
      document.getElementById("donutHp").style.width     = (dp * 100) + "%";
      document.getElementById("donutHp").style.background = hpColor(dp);
      document.getElementById("donutMode").textContent   = donut.mode;
    }

    function renderInventory() {
      const counts = {};
      for (const id of state.entities.carl.inventory)
        counts[id] = (counts[id] || 0) + 1;
      document.getElementById("inventoryList").innerHTML =
        Object.entries(counts).map(([id, n]) => {
          const item    = state.items[id];
          const equipped = Object.values(state.entities.carl.equipment).includes(id);
          return `<div class="item-line"><span>${item.name}${n > 1 ? " x"+n : ""}</span><span>${equipped ? "equipped" : item.slot}</span></div>`;
        }).join("") || `<div class="item-line"><span>Empty</span><span>sad</span></div>`;
    }

    function renderQuests() {
      document.getElementById("questList").innerHTML = state.quests.map(quest =>
        `<div class="quest-card ${quest.complete ? "done" : ""}">
          <div class="quest-check"></div>
          <div>
            <div class="quest-name">${quest.name}</div>
            <div class="quest-desc">${quest.desc} ${quest.current}/${quest.target}</div>
          </div>
        </div>`).join("");
    }

    function renderViewers() {
      for (const key of ["party","carl","donut"]) {
        document.getElementById(key+"ViewerText").textContent = state.viewer[key];
        document.getElementById(key+"Viewer").style.width = Math.min(100, state.viewer[key] * 10) + "%";
      }
    }

    function renderTimers() {
      const pct = state.timer / maxTimer;
      document.getElementById("timerNumber").textContent = state.timer;
      document.getElementById("turnCount").textContent   = "Turn " + state.turn + " · Tutorial Guild";
      document.getElementById("floorFill").style.width  = (pct * 100) + "%";
      const cls = "timer-number" + (pct <= .25 ? " danger" : pct <= .55 ? " warning" : "");
      document.getElementById("timerNumber").className  = cls;
    }

    function renderSystem() {
      document.getElementById("systemLog").innerHTML = state.systemLog
        .map((line, idx, arr) =>
          `<div class="sys-line ${idx === arr.length-1 ? "new" : ""}">${line}</div>`)
        .join("");
    }

    function showBanner(text) {
      const banner = document.getElementById("questBanner");
      banner.textContent = text;
      banner.classList.remove("show");
      void banner.offsetWidth;
      banner.classList.add("show");
    }

    /* ─── KEYBOARD INPUT ────────────────────────────────────────── */
    document.getElementById("commandInput").addEventListener("keydown", e => {
      if (e.key === "Enter") {
        const inp = e.currentTarget;
        runAction(inp.value);
        inp.value = "";
      }
    });

    document.addEventListener("keydown", e => {
      if (e.target.id === "commandInput" && e.key !== "Escape") return;
      const key = e.key.toLowerCase();
      // zoom keys handled above already, skip them here
      if ("wasdxtouicepbfhrvlkq".includes(key) && key.length === 1) {
        e.preventDefault();
        runAction(key);
      }
    });

    /* ─── INIT ──────────────────────────────────────────────────── */
    document.getElementById("controlsLine").innerHTML =
      controls.map(c => `<span class="control-pill">${c}</span>`).join("");

    applyZoom();
    system("Welcome, Carl. You have been registered while aggressively failing to wear complete clothing.");
    render();
  </script>
</body>
